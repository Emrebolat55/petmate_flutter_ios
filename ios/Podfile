# Resilient Podfile for Flutter CI/CD
platform :ios, '15.0'

# --- DYNAMIC PODHELPER LOCATOR ---
# This ensures we find podhelper.rb regardless of environment (Local vs CI)
def podhelper_path
  # 1. Priority: Environment variable set by GitHub Actions or Codemagic
  flutter_root = ENV['FLUTTER_ROOT']
  if flutter_root && !flutter_root.empty?
    path = File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb')
    return path if File.exist?(path)
  end

  # 2. Secondary: Read from Generated.xcconfig
  xcconfig_path = File.expand_path(File.join('Flutter', 'Generated.xcconfig'), __dir__)
  if File.exist?(xcconfig_path)
    File.foreach(xcconfig_path) do |line|
      matches = line.match(/\s*FLUTTER_ROOT\s*=\s*(.*)/)
      if matches
        root = matches[1].strip
        path = File.join(root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb')
        return path if File.exist?(path)
      end
    end
  end

  # 3. Fallback: Standard relative path
  return File.expand_path(File.join('Flutter', 'podhelper.rb'), __dir__)
end

required_file = podhelper_path
puts "Loading Flutter podhelper from: #{required_file}"
require required_file
# ---------------------------------

target 'Runner' do
  # static linkage is critical for Firebase/Google Maps compatibility
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Force iOS 15.0 target
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      # Resolve modular header conflicts
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
    end
  end
end
