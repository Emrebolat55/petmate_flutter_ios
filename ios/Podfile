# Professional CI/CD Podfile for Flutter
platform :ios, '14.0'

# Load podhelper directly from Flutter SDK (Robust for CI)
flutter_sdk_path = ENV['FLUTTER_ROOT']
if flutter_sdk_path.nil?
  # Fallback for local development if FLUTTER_ROOT is not set
  # This assumes a standard relative path if running on a Mac locally
  podhelper_path = File.expand_path(File.join('..', 'Flutter', 'podhelper.rb'), __FILE__)
else
  podhelper_path = File.join(flutter_sdk_path, 'packages', 'flutter_tools', 'bin', 'podhelper.rb')
end

if File.exist?(podhelper_path)
  require podhelper_path
else
  raise "podhelper.rb not found at #{podhelper_path}. Ensure Flutter SDK is installed and FLUTTER_ROOT is set."
end

project 'Runner', {
  'Debug' => :debug,
  'Release' => :release,
  'Profile' => :profile,
}

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Fix for Firebase and other non-modular headers
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
    end
  end
end
